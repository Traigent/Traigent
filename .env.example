# Traigent Local Development Environment Template
# Copy this file to .env in the project root and fill in your values

# =============================================================================
# LLM Provider API Keys (at least one required for real API calls)
# =============================================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# =============================================================================
# Traigent Configuration
# =============================================================================

# Mock Mode - Set to "true" to run examples without real API calls
# Recommended for first-time users and testing
TRAIGENT_MOCK_LLM=true

# Traigent Cloud API Key (optional - for cloud features)
# Get your key from https://traigent.ai
TRAIGENT_API_KEY=

# Backend URLs are only needed when you are running a local backend.
# Leave these unset for the default Traigent Cloud / CLI configuration.
# TRAIGENT_API_URL=http://localhost:5000/api/v1
# TRAIGENT_BACKEND_URL=http://localhost:5000

# Local Results Storage
# Default: ~/.traigent
TRAIGENT_RESULTS_FOLDER=~/.traigent

# =============================================================================
# Optional: Logging Configuration
# =============================================================================
# TRAIGENT_LOG_LEVEL=INFO
