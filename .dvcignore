# Add patterns of files/directories to ignore by DVC
# Similar to .gitignore

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so

# Virtual environments
venv/
env/
ENV/
traigent_test_env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Temporary files
*.tmp
*.log
*.bak
*~

# OS files
.DS_Store
Thumbs.db

# Test coverage
.coverage
htmlcov/
*.cover
.pytest_cache/

# Build artifacts
build/
dist/
*.egg-info/
*.egg
