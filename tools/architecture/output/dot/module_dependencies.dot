digraph TraigentArchitecture {
    rankdir=TB;
    node [shape=box, style=filled, fontname="Helvetica"];
    edge [fontsize=10];

    // Color scheme by layer
    subgraph cluster_legend {
        label="Layer Legend";
        style=dashed;
        l5 [label="API/CLI (L5)" fillcolor="#e8f5e9"];
        l4 [label="Core (L4)" fillcolor="#fff3e0"];
        l3 [label="Services (L3)" fillcolor="#e3f2fd"];
        l2 [label="Adapters (L2)" fillcolor="#fce4ec"];
        l1 [label="Utils (L1)" fillcolor="#f3e5f5"];
    }

    // Package nodes
    _version [label="_version" fillcolor="#ffffff"];
    adapters [label="adapters" fillcolor="#ffffff"];
    agents [label="agents" fillcolor="#ffffff"];
    api [label="api" fillcolor="#e8f5e9"];
    cli [label="cli" fillcolor="#e8f5e9"];
    cloud [label="cloud" fillcolor="#e3f2fd"];
    config [label="config" fillcolor="#fce4ec"];
    core [label="core" fillcolor="#fff3e0"];
    evaluators [label="evaluators" fillcolor="#e3f2fd"];
    integrations [label="integrations" fillcolor="#fce4ec"];
    invokers [label="invokers" fillcolor="#ffffff"];
    metrics [label="metrics" fillcolor="#ffffff"];
    optimizers [label="optimizers" fillcolor="#e3f2fd"];
    security [label="security" fillcolor="#fce4ec"];
    storage [label="storage" fillcolor="#f3e5f5"];
    telemetry [label="telemetry" fillcolor="#f3e5f5"];
    traigent [label="traigent" fillcolor="#ffffff"];
    tvl [label="tvl" fillcolor="#ffffff"];
    utils [label="utils" fillcolor="#f3e5f5"];
    visualization [label="visualization" fillcolor="#ffffff"];

    // Dependencies
    traigent -> _version [penwidth=1.9, color="#1976d2", label="3"];
    traigent -> adapters [penwidth=1.3, color="#1976d2", label="1"];
    traigent -> agents [penwidth=1.3, color="#1976d2", label="1"];
    traigent -> api [penwidth=5.0, color="#d32f2f", label="42"];
    traigent -> cli [penwidth=2.5, color="#1976d2", label="5"];
    traigent -> cloud [penwidth=5.0, color="#d32f2f", label="45"];
    traigent -> config [penwidth=5.0, color="#d32f2f", label="52"];
    traigent -> core [penwidth=5.0, color="#d32f2f", label="51"];
    traigent -> evaluators [penwidth=5.0, color="#d32f2f", label="31"];
    traigent -> integrations [penwidth=2.8, color="#1976d2", label="6"];
    traigent -> invokers [penwidth=4.0, color="#1976d2", label="10"];
    traigent -> metrics [penwidth=1.6, color="#1976d2", label="2"];
    traigent -> optimizers [penwidth=5.0, color="#d32f2f", label="39"];
    traigent -> security [penwidth=2.5, color="#1976d2", label="5"];
    traigent -> storage [penwidth=1.9, color="#1976d2", label="3"];
    traigent -> telemetry [penwidth=1.3, color="#1976d2", label="1"];
    traigent -> tvl [penwidth=2.2, color="#1976d2", label="4"];
    traigent -> utils [penwidth=5.0, color="#d32f2f", label="206"];
    traigent -> visualization [penwidth=1.6, color="#1976d2", label="2"];
}