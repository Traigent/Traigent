digraph HubModules {
    rankdir=LR;
    node [shape=box, style=filled, fontname="Helvetica", fontsize=11];
    label="Hub Modules (High Fan-In)\nModules imported by many others";
    labelloc=t;
    fontsize=16;

    hub0 [label="utils.logging\n103 dependents" fillcolor="#d32f2f"];
    hub1 [label="utils.exceptions\n52 dependents" fillcolor="#d32f2f"];
    hub2 [label="api.types\n35 dependents" fillcolor="#ef5350"];
    hub3 [label="config.types\n26 dependents" fillcolor="#ef5350"];
    hub4 [label="evaluators.base\n25 dependents" fillcolor="#ef5350"];
    hub5 [label="utils.validation\n20 dependents" fillcolor="#ef5350"];
    hub6 [label="optimizers.base\n15 dependents" fillcolor="#ffcc80"];
    hub7 [label="core.objectives\n13 dependents" fillcolor="#ffcc80"];
    hub8 [label="cloud.models\n11 dependents" fillcolor="#ffcc80"];
    hub9 [label="cloud.backend_client\n8 dependents" fillcolor="#fff9c4"];
    hub10 [label="config.backend_config\n8 dependents" fillcolor="#fff9c4"];
    hub11 [label="invokers.base\n7 dependents" fillcolor="#fff9c4"];
    hub12 [label="utils.retry\n6 dependents" fillcolor="#fff9c4"];
    hub13 [label="core.utils\n6 dependents" fillcolor="#fff9c4"];
    hub14 [label="api.functions\n5 dependents" fillcolor="#fff9c4"];

    subgraph cluster_legend {
        label="Stability Risk";
        style=dashed;
        leg1 [label="Critical (50+)" fillcolor="#d32f2f"];
        leg2 [label="High (20-50)" fillcolor="#ef5350"];
        leg3 [label="Medium (10-20)" fillcolor="#ffcc80"];
        leg4 [label="Low (5-10)" fillcolor="#fff9c4"];
    }
}