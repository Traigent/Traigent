{
  "name": "@traigent/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Traigent LLM optimization platform",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./langchain": {
      "types": "./dist/integrations/langchain/index.d.ts",
      "import": "./dist/integrations/langchain/index.js",
      "require": "./dist/integrations/langchain/index.cjs"
    },
    "./vercel-ai": {
      "types": "./dist/integrations/vercel-ai/index.d.ts",
      "import": "./dist/integrations/vercel-ai/index.js",
      "require": "./dist/integrations/vercel-ai/index.cjs"
    },
    "./openai": {
      "types": "./dist/integrations/openai/index.d.ts",
      "import": "./dist/integrations/openai/index.js",
      "require": "./dist/integrations/openai/index.cjs"
    },
    "./babel-plugin-seamless": {
      "import": "./dist/seamless/babel-plugin.js",
      "require": "./dist/seamless/babel-plugin.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "traigent-js": "./dist/cli/runner.js",
    "traigent": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "walkthrough",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && tsup --config tsup.cli.config.ts",
    "build:sdk": "tsup",
    "build:cli": "tsup --config tsup.cli.config.ts",
    "dev": "tsup --watch",
    "smoke:example": "npm run build:sdk && node examples/native-optimization.mjs",
    "smoke:examples": "npm run build:sdk && bash examples/test_all_examples.sh",
    "smoke:walkthrough": "npm run build:sdk && bash walkthrough/test_all_examples.sh",
    "test": "vitest run",
    "test:cross-sdk": "vitest run tests/cross-sdk/**/*.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests --ext .ts",
    "typecheck": "tsc --noEmit",
    "smoke:codemod": "npm run build && node dist/cli/index.js migrate seamless examples/adoption/seamless/codemod-target.mjs",
    "benchmark:cross-sdk": "npm run build:sdk && node scripts/run-cross-sdk-benchmark.mjs",
    "sonar": "npx sonar-scanner -Dsonar.token=$SONAR_LOCAL_TOKEN",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@babel/generator": "^7.28.5",
    "@babel/parser": "^7.28.5",
    "@babel/traverse": "^7.28.5",
    "@babel/types": "^7.28.5",
    "yaml": "^2.8.2",
    "zod": "^3.22.0"
  },
  "peerDependencies": {
    "@babel/core": ">=7.0.0",
    "@langchain/core": ">=0.1.0",
    "ai": ">=3.0.0",
    "openai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@babel/core": {
      "optional": true
    },
    "@langchain/core": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@langchain/core": "^0.2.0",
    "@langchain/openai": "^0.2.0",
    "@types/babel__core": "^7.20.5",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^1.6.1",
    "ai": "^3.0.0",
    "eslint": "^8.0.0",
    "openai": "^4.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "traigent",
    "llm",
    "optimization",
    "langchain",
    "openai",
    "ai"
  ],
  "author": "Traigent",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/traigent/traigent-js.git"
  }
}
