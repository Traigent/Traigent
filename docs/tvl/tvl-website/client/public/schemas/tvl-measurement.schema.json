{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/tvl-measurement.schema.json",
  "title": "TVL Measurement Bundle",
  "type": "object",
  "required": ["objectives"],
  "properties": {
    "bundle_id": { "type": "string" },
    "config_id": { "type": "string" },
    "module_id": { "type": "string" },
    "objectives": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "observed": { "type": "number" },
          "delta": { "type": "number" },
          "p_value": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
          "lower": { "type": "number" },
          "upper": { "type": "number" },
          "metric": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "chance": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "observed": { "type": "number" },
          "p_value": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
        },
        "additionalProperties": true
      }
    },
    "summary": { "type": "object" }
  },
  "additionalProperties": false
}

