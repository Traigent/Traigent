[15.67, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[16.02, "o", "\u001b[0;36m\u001b[1m# Step 2: Define your LLM agent with tunable parameters\u001b[0m\r\n"]
[16.37, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[16.72, "o", "\r\n"]
[16.97, "o", "\u001b[0;35mimport\u001b[0m traigent\r\n"]
[17.32, "o", "\u001b[0;35mfrom\u001b[0m langchain_openai \u001b[0;35mimport\u001b[0m ChatOpenAI\r\n"]
[17.67, "o", "\r\n"]
[17.92, "o", "\u001b[0;36m@traigent.optimize\u001b[0m(\r\n"]
[18.27, "o", "    \u001b[2m# Define TUNABLE PARAMETERS - what to optimize\u001b[0m\r\n"]
[18.62, "o", "    configuration_space={\r\n"]
[18.97, "o", "        \u001b[0;32m\"model\"\u001b[0m: [\"gpt-3.5-turbo\", \"gpt-4o-mini\", \"gpt-4o\"],\r\n"]
[19.32, "o", "        \u001b[0;32m\"temperature\"\u001b[0m: [0.1, 0.5, 0.9],\r\n"]
[19.67, "o", "        \u001b[0;32m\"max_tokens\"\u001b[0m: [500, 1000, 2000]\r\n"]
[20.02, "o", "    },\r\n"]
[20.37, "o", "\r\n"]
[20.62, "o", "    \u001b[2m# Define OBJECTIVES - what to optimize for\u001b[0m\r\n"]
[20.97, "o", "    objectives=[\u001b[0;32m\"accuracy\"\u001b[0m, \u001b[0;32m\"cost\"\u001b[0m],\r\n"]
[21.32, "o", "\r\n"]
[21.57, "o", "    \u001b[2m# Evaluation dataset for testing\u001b[0m\r\n"]
[21.92, "o", "    eval_dataset=\u001b[0;32m\"data/qa_samples.jsonl\"\u001b[0m\r\n"]
[22.27, "o", ")\r\n"]
[22.62, "o", "\u001b[0;34mdef\u001b[0m \u001b[1;33mqa_agent\u001b[0m(question: str) -> str:\r\n"]
[22.97, "o", "    \u001b[2m\"\"\"Q&A agent with tunable parameters\"\"\"\u001b[0m\r\n"]
[23.32, "o", "    llm = ChatOpenAI(\r\n"]
[23.67, "o", "        model=\u001b[0;32m\"gpt-3.5-turbo\"\u001b[0m,    \u001b[2m# Traigent will tune this\u001b[0m\r\n"]
[24.02, "o", "        temperature=\u001b[0;36m0.7\u001b[0m           \u001b[2m# Traigent will tune this\u001b[0m\r\n"]
[24.37, "o", "    )\r\n"]
[24.72, "o", "    \u001b[0;35mreturn\u001b[0m llm.invoke(question).content\r\n"]
[25.07, "o", "\r\n"]
[25.32, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[25.67, "o", "\u001b[0;36m\u001b[1m# Step 3: Run the optimization\u001b[0m\r\n"]
