[1.9300000000000013, "o", "\r\n"]
[2.4300000000000015, "o", "\r\n"]
[2.4500000000000015, "o", "import traigent\r\n"]
[2.5000000000000013, "o", "from langchain_openai import ChatOpenAI\r\n"]
[2.550000000000001, "o", "\r\n"]
[2.570000000000001, "o", "@traigent.optimize(\r\n"]
[2.620000000000001, "o", "    # Define TUNED VARIABLES - parameters to optimize\r\n"]
[2.670000000000001, "o", "    configuration_space={\r\n"]
[2.7200000000000006, "o", "        \"model\": [\"gpt-3.5-turbo\", \"gpt-4o-mini\", \"gpt-4o\"],\r\n"]
[2.7700000000000005, "o", "        \"temperature\": [0.1, 0.5, 0.9],\r\n"]
[2.8200000000000003, "o", "        \"max_tokens\": [500, 1000, 2000]\r\n"]
[2.87, "o", "    },\r\n"]
[2.92, "o", "\r\n"]
[2.94, "o", "    # Define OBJECTIVES - what to optimize for\r\n"]
[2.9899999999999998, "o", "    objectives=[\"accuracy\", \"cost\"],\r\n"]
[3.0399999999999996, "o", "\r\n"]
[3.0599999999999996, "o", "    # Evaluation dataset for testing\r\n"]
[3.1099999999999994, "o", "    eval_dataset=\"qa_samples.jsonl\"\r\n"]
[3.1599999999999993, "o", ")\r\n"]
[3.209999999999999, "o", "def qa_agent(question: str) -> str:\r\n"]
[3.259999999999999, "o", "    \"\"\"Q&A agent with tunable parameters\"\"\"\r\n"]
[3.3099999999999987, "o", "    llm = ChatOpenAI(\r\n"]
[3.3599999999999985, "o", "        model=\"gpt-3.5-turbo\",    # Traigent will tune this\r\n"]
[3.4099999999999984, "o", "        temperature=0.7           # Traigent will tune this\r\n"]
[3.459999999999998, "o", "    )\r\n"]
[3.509999999999998, "o", "    return llm.invoke(question).content\r\n"]
[3.559999999999998, "o", "\r\n"]
