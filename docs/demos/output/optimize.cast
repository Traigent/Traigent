[37.77, "o", "Starting optimization with \u001b[0;36mgrid search\u001b[0m...\r\n"]
[38.12, "o", "Objectives: \u001b[0;32maccuracy\u001b[0m, \u001b[1;33mcost\u001b[0m\r\n"]
[38.47, "o", "Configuration space: \u001b[1m27 combinations\u001b[0m (3 models \u00d7 3 temps \u00d7 3 tokens)\r\n"]
[38.82, "o", "Cost limit: \u001b[1;33m$2.00\u001b[0m\r\n"]
[39.17, "o", "\r\n"]
[39.42, "o", "[\u001b[2m 1/27\u001b[0m] Testing: gpt-3.5-turbo, temp=0.1, tokens=500\r\n"]
[39.77, "o", "        \u001b[2maccuracy=\u001b[0m0.72  \u001b[2mcost=\u001b[0m\u001b[1;33m$0.002\u001b[0m\r\n"]
[40.12, "o", "[\u001b[2m 2/27\u001b[0m] Testing: gpt-3.5-turbo, temp=0.1, tokens=1000\r\n"]
[40.47, "o", "        \u001b[2maccuracy=\u001b[0m0.75  \u001b[2mcost=\u001b[0m\u001b[1;33m$0.003\u001b[0m\r\n"]
[40.82, "o", "[\u001b[2m 3/27\u001b[0m] Testing: gpt-3.5-turbo, temp=0.5, tokens=500\r\n"]
[41.17, "o", "        \u001b[2maccuracy=\u001b[0m0.68  \u001b[2mcost=\u001b[0m\u001b[1;33m$0.002\u001b[0m\r\n"]
[41.52, "o", "\u001b[2m...\u001b[0m\r\n"]
[41.87, "o", "[\u001b[1m15/27\u001b[0m] Testing: gpt-4o-mini, temp=0.1, tokens=1000\r\n"]
[42.22, "o", "        \u001b[2maccuracy=\u001b[0m\u001b[0;32m\u001b[1m0.89\u001b[0m  \u001b[2mcost=\u001b[0m\u001b[1;33m$0.008\u001b[0m  \u001b[0;32m\u2190 New best!\u001b[0m\r\n"]
[42.57, "o", "\u001b[2m...\u001b[0m\r\n"]
[42.92, "o", "[\u001b[2m27/27\u001b[0m] Testing: gpt-4o, temp=0.9, tokens=2000\r\n"]
[43.27, "o", "        \u001b[2maccuracy=\u001b[0m0.91  \u001b[2mcost=\u001b[0m\u001b[1;33m$0.045\u001b[0m  \u001b[2m(higher cost)\u001b[0m\r\n"]
[43.62, "o", "\r\n"]
[43.87, "o", "\u001b[0;32m\u2713\u001b[0m Optimization complete! Total cost: \u001b[1;33m$0.42\u001b[0m (within $2.00 limit)\r\n"]
[44.22, "o", "\r\n"]
[44.47, "o", "\u001b[0;32m\u001b[1m\u250c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2510\u001b[0m\r\n"]
[44.82, "o", "\u001b[0;32m\u001b[1m\u2502  BEST CONFIGURATION FOUND                                      \u2502\u001b[0m\r\n"]
[45.17, "o", "\u001b[0;32m\u001b[1m\u2514\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2518\u001b[0m\r\n"]
[45.52, "o", "  model:       \u001b[0;36m\u001b[1mgpt-4o-mini\u001b[0m\r\n"]
[45.87, "o", "  temperature: \u001b[0;36m\u001b[1m0.1\u001b[0m\r\n"]
[46.22, "o", "  max_tokens:  \u001b[0;36m\u001b[1m1000\u001b[0m\r\n"]
[46.57, "o", "\r\n"]
[46.82, "o", "  \u001b[1mMETRICS:\u001b[0m\r\n"]
[47.17, "o", "  accuracy:    \u001b[0;32m\u001b[1m0.89 (89%)\u001b[0m\r\n"]
[47.52, "o", "  cost:        \u001b[1;33m\u001b[1m$0.008\u001b[0m per query\r\n"]
[47.87, "o", "\r\n"]
[48.12, "o", "  \u001b[1mCompared to default\u001b[0m (gpt-3.5-turbo, temp=0.7):\r\n"]
[48.47, "o", "    \u001b[0;32m\u2191 +17% accuracy\u001b[0m improvement\r\n"]
[48.82, "o", "    \u001b[0;32m\u2193 Best cost/accuracy trade-off\u001b[0m\r\n"]
[49.17, "o", "\r\n"]
[49.42, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[49.77, "o", "\u001b[0;36m\u001b[1m# Step 4: Apply and use the optimized agent\u001b[0m\r\n"]
[50.12, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[50.47, "o", "\r\n"]
[50.72, "o", "\u001b[2m# Apply the optimized configuration\u001b[0m\r\n"]
[51.07, "o", "results = \u001b[0;35mawait\u001b[0m qa_agent.optimize()\r\n"]
[51.42, "o", "qa_agent.apply_best_config(results)\r\n"]
[51.77, "o", "\r\n"]
[52.02, "o", "\u001b[2m# Now qa_agent uses: gpt-4o-mini, temp=0.1, tokens=1000\u001b[0m\r\n"]
[52.37, "o", "answer = qa_agent(\u001b[0;32m\"What is machine learning?\"\u001b[0m)\r\n"]
[52.72, "o", "\u001b[2m# \u2192 Uses optimized parameters automatically!\u001b[0m\r\n"]
[53.07, "o", "\r\n"]
[56.32, "o", ""]
