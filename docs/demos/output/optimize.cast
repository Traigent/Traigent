[20.459999999999994, "o", "        \u001b[2maccuracy=\u001b[0m0.91  \u001b[2mcost=\u001b[0m\u001b[1;33m$0.045\u001b[0m  \u001b[2m(higher cost)\u001b[0m\r\n"]
[20.609999999999992, "o", "\r\n"]
[20.709999999999994, "o", "\u001b[0;32m\u2713\u001b[0m Optimization complete! Total cost: \u001b[1;33m$0.42\u001b[0m (within $2.00 limit)\r\n"]
[20.859999999999992, "o", "\r\n"]
[20.959999999999994, "o", "\u001b[0;32m\u001b[1m\u250c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2510\u001b[0m\r\n"]
[21.109999999999992, "o", "\u001b[0;32m\u001b[1m\u2502  BEST CONFIGURATION FOUND                                      \u2502\u001b[0m\r\n"]
[21.25999999999999, "o", "\u001b[0;32m\u001b[1m\u2514\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2518\u001b[0m\r\n"]
[21.40999999999999, "o", "  model:       \u001b[0;36m\u001b[1mgpt-4o-mini\u001b[0m\r\n"]
[21.559999999999988, "o", "  temperature: \u001b[0;36m\u001b[1m0.1\u001b[0m\r\n"]
[21.709999999999987, "o", "  max_tokens:  \u001b[0;36m\u001b[1m1000\u001b[0m\r\n"]
[21.859999999999985, "o", "\r\n"]
[21.959999999999987, "o", "  \u001b[1mMETRICS:\u001b[0m\r\n"]
[22.109999999999985, "o", "  accuracy:    \u001b[0;32m\u001b[1m0.89 (89%)\u001b[0m\r\n"]
[22.259999999999984, "o", "  cost:        \u001b[1;33m\u001b[1m$0.008\u001b[0m per query\r\n"]
[22.409999999999982, "o", "\r\n"]
[22.509999999999984, "o", "  \u001b[1mCompared to default\u001b[0m (gpt-3.5-turbo, temp=0.7):\r\n"]
[22.659999999999982, "o", "    \u001b[0;32m\u2191 +17% accuracy\u001b[0m improvement\r\n"]
[22.80999999999998, "o", "    \u001b[0;32m\u2193 Best cost/accuracy trade-off\u001b[0m\r\n"]
[22.95999999999998, "o", "\r\n"]
[23.05999999999998, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[23.20999999999998, "o", "\u001b[0;36m\u001b[1m# Step 4: Apply and use the optimized agent\u001b[0m\r\n"]
[23.359999999999978, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[23.509999999999977, "o", "\r\n"]
[23.609999999999978, "o", "\u001b[2m# Apply the optimized configuration\u001b[0m\r\n"]
[23.759999999999977, "o", "results = \u001b[0;35mawait\u001b[0m qa_agent.optimize()\r\n"]
[23.909999999999975, "o", "qa_agent.apply_best_config(results)\r\n"]
[24.059999999999974, "o", "\r\n"]
[24.159999999999975, "o", "\u001b[2m# Now qa_agent uses: gpt-4o-mini, temp=0.1, tokens=1000\u001b[0m\r\n"]
[24.309999999999974, "o", "answer = qa_agent(\u001b[0;32m\"What is machine learning?\"\u001b[0m)\r\n"]
[24.459999999999972, "o", "\u001b[2m# \u2192 Uses optimized parameters automatically!\u001b[0m\r\n"]
[24.60999999999997, "o", "\r\n"]
[26.709999999999972, "o", ""]
