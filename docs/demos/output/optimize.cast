[7.759999999999987, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[7.909999999999988, "o", "\u001b[0;36m\u001b[1m# Step 2: Define your LLM agent with tunable parameters\u001b[0m\r\n"]
[8.059999999999988, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[8.209999999999988, "o", "\r\n"]
[8.309999999999988, "o", "\u001b[0;35mimport\u001b[0m traigent\r\n"]
[8.459999999999988, "o", "\u001b[0;35mfrom\u001b[0m langchain_openai \u001b[0;35mimport\u001b[0m ChatOpenAI\r\n"]
[8.609999999999989, "o", "\r\n"]
[8.709999999999988, "o", "\u001b[0;36m@traigent.optimize\u001b[0m(\r\n"]
[8.859999999999989, "o", "    \u001b[2m# Define TUNABLE PARAMETERS - what to optimize\u001b[0m\r\n"]
[9.00999999999999, "o", "    configuration_space={\r\n"]
[9.15999999999999, "o", "        \u001b[0;32m\"model\"\u001b[0m: [\"gpt-3.5-turbo\", \"gpt-4o-mini\", \"gpt-4o\"],\r\n"]
[9.30999999999999, "o", "        \u001b[0;32m\"temperature\"\u001b[0m: [0.1, 0.5, 0.9],\r\n"]
[9.45999999999999, "o", "        \u001b[0;32m\"max_tokens\"\u001b[0m: [500, 1000, 2000]\r\n"]
[9.60999999999999, "o", "    },\r\n"]
[9.759999999999991, "o", "\r\n"]
[9.85999999999999, "o", "    \u001b[2m# Define OBJECTIVES - what to optimize for\u001b[0m\r\n"]
[10.009999999999991, "o", "    objectives=[\u001b[0;32m\"accuracy\"\u001b[0m, \u001b[0;32m\"cost\"\u001b[0m],\r\n"]
[10.159999999999991, "o", "\r\n"]
[10.259999999999991, "o", "    \u001b[2m# Evaluation dataset for testing\u001b[0m\r\n"]
[10.409999999999991, "o", "    eval_dataset=\u001b[0;32m\"qa_samples.jsonl\"\u001b[0m\r\n"]
[10.559999999999992, "o", ")\r\n"]
[10.709999999999992, "o", "\u001b[0;34mdef\u001b[0m \u001b[1;33mqa_agent\u001b[0m(question: str) -> str:\r\n"]
[10.859999999999992, "o", "    \u001b[2m\"\"\"Q&A agent with tunable parameters\"\"\"\u001b[0m\r\n"]
[11.009999999999993, "o", "    llm = ChatOpenAI(\r\n"]
[11.159999999999993, "o", "        model=\u001b[0;32m\"gpt-3.5-turbo\"\u001b[0m,    \u001b[2m# TraiGent will tune this\u001b[0m\r\n"]
[11.309999999999993, "o", "        temperature=\u001b[0;36m0.7\u001b[0m           \u001b[2m# TraiGent will tune this\u001b[0m\r\n"]
[11.459999999999994, "o", "    )\r\n"]
[11.609999999999994, "o", "    \u001b[0;35mreturn\u001b[0m llm.invoke(question).content\r\n"]
[11.759999999999994, "o", "\r\n"]
[11.859999999999994, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[12.009999999999994, "o", "\u001b[0;36m\u001b[1m# Step 3: Run the optimization\u001b[0m\r\n"]
[12.159999999999995, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
