[20.009999999999998, "o", "        \u001b[2maccuracy=\u001b[0m\u001b[0;32m\u001b[1m0.89\u001b[0m  \u001b[2mcost=\u001b[0m\u001b[1;33m$0.008\u001b[0m  \u001b[0;32m\u2190 New best!\u001b[0m\r\n"]
[20.159999999999997, "o", "\u001b[2m...\u001b[0m\r\n"]
