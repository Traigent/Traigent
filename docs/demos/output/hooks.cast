[0.0, "o", "\u001b[H\u001b[2J\u001b[3J\u001b[0;34m\u001b[1m\u250c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2510\u001b[0m\r\n"]
[0.15, "o", "\u001b[0;34m\u001b[1m\u2502  \ud83d\udd14 TraiGent: Optimization Callbacks                           \u2502\u001b[0m\r\n"]
[0.3, "o", "\u001b[0;34m\u001b[1m\u2514\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2518\u001b[0m\r\n"]
[0.44999999999999996, "o", "\r\n"]
[0.5499999999999999, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[0.7, "o", "\u001b[0;36m\u001b[1m# Lifecycle Hooks for Monitoring\u001b[0m\r\n"]
[0.85, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[1.0, "o", "\r\n"]
[1.1, "o", "Available callback events:\r\n"]
[1.25, "o", "  \u001b[0;36mon_optimization_start\u001b[0m   \u001b[2m\u2500\u001b[0m Called when optimization begins\r\n"]
[1.4, "o", "  \u001b[0;36mon_trial_start\u001b[0m          \u001b[2m\u2500\u001b[0m Called before each trial\r\n"]
[1.5499999999999998, "o", "  \u001b[0;36mon_trial_complete\u001b[0m       \u001b[2m\u2500\u001b[0m Called after each trial\r\n"]
[1.6999999999999997, "o", "  \u001b[0;36mon_optimization_complete\u001b[0m \u001b[2m\u2500\u001b[0m Called when optimization ends\r\n"]
[1.8499999999999996, "o", "\r\n"]
[1.9499999999999997, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[2.0999999999999996, "o", "\u001b[0;36m\u001b[1m# Built-in Callbacks\u001b[0m\r\n"]
[2.2499999999999996, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[2.3999999999999995, "o", "\r\n"]
[2.4999999999999996, "o", "\u001b[0;35mfrom\u001b[0m traigent.utils.callbacks \u001b[0;35mimport\u001b[0m (\r\n"]
[2.6499999999999995, "o", "    \u001b[0;36mProgressBarCallback\u001b[0m,     \u001b[2m# Visual progress bar\u001b[0m\r\n"]
[2.7999999999999994, "o", "    \u001b[0;36mLoggingCallback\u001b[0m,         \u001b[2m# Log all events\u001b[0m\r\n"]
[2.9499999999999993, "o", "    \u001b[0;36mStatisticsCallback\u001b[0m,      \u001b[2m# Collect optimization stats\u001b[0m\r\n"]
[3.099999999999999, "o", "    \u001b[0;36mDetailedProgressCallback\u001b[0m  \u001b[2m# Comprehensive output\u001b[0m\r\n"]
[3.249999999999999, "o", ")\r\n"]
[3.399999999999999, "o", "\r\n"]
[3.499999999999999, "o", "\u001b[0;36m@traigent.optimize\u001b[0m(\r\n"]
[3.649999999999999, "o", "    configuration_space={\u001b[0;32m\"model\"\u001b[0m: [\"gpt-4o-mini\", \"gpt-4o\"]},\r\n"]
[3.799999999999999, "o", "    objectives=[\u001b[0;32m\"accuracy\"\u001b[0m],\r\n"]
[3.949999999999999, "o", "    callbacks=[\r\n"]
[4.099999999999999, "o", "        ProgressBarCallback(width=\u001b[0;36m50\u001b[0m),\r\n"]
[4.249999999999999, "o", "        StatisticsCallback()\r\n"]
[4.3999999999999995, "o", "    ]\r\n"]
[4.55, "o", ")\r\n"]
[4.7, "o", "\u001b[0;34mdef\u001b[0m \u001b[1;33mmy_agent\u001b[0m(query: str) -> str:\r\n"]
[4.8500000000000005, "o", "    ...\r\n"]
[5.000000000000001, "o", "\r\n"]
[5.1000000000000005, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[5.250000000000001, "o", "\u001b[0;36m\u001b[1m# ProgressBarCallback in Action\u001b[0m\r\n"]
[5.400000000000001, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[5.550000000000002, "o", "\r\n"]
[5.650000000000001, "o", "Starting optimization with \u001b[0;36mgrid search\u001b[0m...\r\n"]
[5.800000000000002, "o", "Objectives: \u001b[0;32maccuracy\u001b[0m\r\n"]
[5.950000000000002, "o", "Configuration space: \u001b[1m5 combinations\u001b[0m\r\n"]
[6.100000000000002, "o", "\r\n"]
[6.200000000000002, "o", "[\u001b[0;32m\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u001b[0m\u001b[2m\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u001b[0m]  20% (1/5) Best: 0.72\r\n"]
[6.350000000000002, "o", "[\u001b[0;32m\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u001b[0m\u001b[2m\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u001b[0m]  40% (2/5) Best: \u001b[0;32m0.78\u001b[0m\r\n"]
[6.500000000000003, "o", "[\u001b[0;32m\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u001b[0m\u001b[2m\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u001b[0m]  60% (3/5) Best: \u001b[0;32m0.85\u001b[0m\r\n"]
[6.650000000000003, "o", "[\u001b[0;32m\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u001b[0m\u001b[2m\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u001b[0m]  80% (4/5) Best: 0.85\r\n"]
[6.800000000000003, "o", "[\u001b[0;32m\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u001b[0m] 100% (5/5) Best: \u001b[0;32m\u001b[1m0.89\u001b[0m\r\n"]
[6.950000000000004, "o", "\r\n"]
[7.050000000000003, "o", "\u001b[0;32m\u2713\u001b[0m Optimization complete! Best score: \u001b[0;32m\u001b[1m0.89\u001b[0m\r\n"]
[7.200000000000004, "o", "\r\n"]
[7.300000000000003, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[7.450000000000004, "o", "\u001b[0;36m\u001b[1m# Creating a Custom Callback\u001b[0m\r\n"]
[7.600000000000004, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[7.750000000000004, "o", "\r\n"]
[7.850000000000004, "o", "\u001b[0;35mfrom\u001b[0m traigent.utils.callbacks \u001b[0;35mimport\u001b[0m OptimizationCallback\r\n"]
[8.000000000000004, "o", "\r\n"]
[8.100000000000003, "o", "\u001b[0;34mclass\u001b[0m \u001b[1;33mSlackNotificationCallback\u001b[0m(OptimizationCallback):\r\n"]
[8.250000000000004, "o", "    \u001b[2m\"\"\"Send Slack notifications on optimization events.\"\"\"\u001b[0m\r\n"]
[8.400000000000004, "o", "\r\n"]
[8.500000000000004, "o", "    \u001b[0;34mdef\u001b[0m \u001b[0;36mon_optimization_start\u001b[0m(self, config_space, objectives, algorithm):\r\n"]
[8.650000000000004, "o", "        slack.post(f\u001b[0;32m\"\ud83d\ude80 Optimization started: {algorithm}\"\u001b[0m)\r\n"]
[8.800000000000004, "o", "\r\n"]
[8.900000000000004, "o", "    \u001b[0;34mdef\u001b[0m \u001b[0;36mon_trial_complete\u001b[0m(self, trial, progress):\r\n"]
[9.050000000000004, "o", "        \u001b[0;35mif\u001b[0m progress.best_score \u001b[0;35mand\u001b[0m progress.best_score > \u001b[0;36m0.9\u001b[0m:\r\n"]
[9.200000000000005, "o", "            slack.post(f\u001b[0;32m\"\ud83c\udfaf New best score: {progress.best_score:.1%}\"\u001b[0m)\r\n"]
[9.350000000000005, "o", "\r\n"]
[9.450000000000005, "o", "    \u001b[0;34mdef\u001b[0m \u001b[0;36mon_optimization_complete\u001b[0m(self, result):\r\n"]
[9.600000000000005, "o", "        slack.post(f\u001b[0;32m\"\u2705 Done! Best: {result.best_config}\"\u001b[0m)\r\n"]
[9.750000000000005, "o", "\r\n"]
[9.850000000000005, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[10.000000000000005, "o", "\u001b[0;36m\u001b[1m# Parameter Importance Analysis\u001b[0m\r\n"]
[10.150000000000006, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[10.300000000000006, "o", "\r\n"]
[10.400000000000006, "o", "stats_callback = StatisticsCallback()\r\n"]
[10.550000000000006, "o", "\r\n"]
[10.650000000000006, "o", "\u001b[2m# After optimization...\u001b[0m\r\n"]
[10.800000000000006, "o", "importance = stats_callback.get_parameter_importance()\r\n"]
[10.950000000000006, "o", "\r\n"]
[11.050000000000006, "o", "\u001b[1mParameter Importance:\u001b[0m\r\n"]
[11.200000000000006, "o", "  model:       \u001b[0;32m\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2591\u2591\u001b[0m \u001b[1m0.85\u001b[0m  \u001b[2m\u2190 Most impactful\u001b[0m\r\n"]
[11.350000000000007, "o", "  temperature: \u001b[1;33m\u2588\u2588\u2588\u2588\u2591\u2591\u2591\u2591\u2591\u2591\u001b[0m \u001b[1m0.42\u001b[0m\r\n"]
[11.500000000000007, "o", "  max_tokens:  \u001b[2m\u2588\u2588\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u001b[0m \u001b[1m0.18\u001b[0m\r\n"]
[11.650000000000007, "o", "\r\n"]
[11.750000000000007, "o", "\u001b[2m\u2192 Model choice has the most impact on results!\u001b[0m\r\n"]
[11.900000000000007, "o", "\r\n"]
[12.000000000000007, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[12.150000000000007, "o", "\u001b[1mCallbacks enable:\u001b[0m\r\n"]
