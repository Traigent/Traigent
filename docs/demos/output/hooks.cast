[8.769999999999992, "o", "\r\n"]
[9.269999999999992, "o", "\r\n"]
[9.289999999999992, "o", "from traigent.utils.callbacks import OptimizationCallback\r\n"]
[9.339999999999993, "o", "\r\n"]
[9.359999999999992, "o", "class SlackNotificationCallback(OptimizationCallback):\r\n"]
[9.409999999999993, "o", "    \"\"\"Send Slack notifications on optimization events.\"\"\"\r\n"]
[9.459999999999994, "o", "\r\n"]
[9.479999999999993, "o", "    def on_optimization_start(self, config_space, objectives, algorithm):\r\n"]
[9.529999999999994, "o", "        slack.post(f\"Optimization started: {algorithm}\")\r\n"]
[9.579999999999995, "o", "\r\n"]
[9.599999999999994, "o", "    def on_trial_complete(self, trial, progress):\r\n"]
[9.649999999999995, "o", "        if progress.best_score and progress.best_score > 0.9:\r\n"]
[9.699999999999996, "o", "            slack.post(f\"New best score: {progress.best_score:.1%}\")\r\n"]
[9.749999999999996, "o", "\r\n"]
[9.769999999999996, "o", "    def on_optimization_complete(self, result):\r\n"]
[9.819999999999997, "o", "        slack.post(f\"Done! Best: {result.best_config}\")\r\n"]
[9.869999999999997, "o", "\r\n"]
[9.889999999999997, "o", "#"]
[9.919999999999996, "o", " "]
[9.949999999999996, "o", "U"]
[9.979999999999995, "o", "s"]
[10.009999999999994, "o", "e"]
