[0.0, "o", "\u001b[H\u001b[2J\u001b[3J\u001b[0;34m\u001b[1m\u250c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2510\u001b[0m\r\n"]
[0.35, "o", "\u001b[0;34m\u001b[1m\u2502  \ud83d\udd14 Traigent: Optimization Callbacks                           \u2502\u001b[0m\r\n"]
[0.7, "o", "\u001b[0;34m\u001b[1m\u2514\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2518\u001b[0m\r\n"]
[1.05, "o", "\r\n"]
[1.3, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[1.65, "o", "\u001b[0;36m\u001b[1m# Lifecycle Hooks for Monitoring\u001b[0m\r\n"]
[2.0, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[2.35, "o", "\r\n"]
[2.6, "o", "Available callback events:\r\n"]
[2.95, "o", "  \u001b[0;36mon_optimization_start\u001b[0m   \u001b[2m\u2500\u001b[0m Called when optimization begins\r\n"]
[3.3, "o", "  \u001b[0;36mon_trial_start\u001b[0m          \u001b[2m\u2500\u001b[0m Called before each trial\r\n"]
[3.65, "o", "  \u001b[0;36mon_trial_complete\u001b[0m       \u001b[2m\u2500\u001b[0m Called after each trial\r\n"]
[4.0, "o", "  \u001b[0;36mon_optimization_complete\u001b[0m \u001b[2m\u2500\u001b[0m Called when optimization ends\r\n"]
[4.35, "o", "\r\n"]
[4.6, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[4.95, "o", "\u001b[0;36m\u001b[1m# Built-in Callbacks\u001b[0m\r\n"]
[5.3, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[5.65, "o", "\r\n"]
[5.9, "o", "\u001b[0;35mfrom\u001b[0m traigent.utils.callbacks \u001b[0;35mimport\u001b[0m (\r\n"]
[6.25, "o", "    \u001b[0;36mProgressBarCallback\u001b[0m,     \u001b[2m# Visual progress bar\u001b[0m\r\n"]
[6.6, "o", "    \u001b[0;36mLoggingCallback\u001b[0m,         \u001b[2m# Log all events\u001b[0m\r\n"]
[6.95, "o", "    \u001b[0;36mStatisticsCallback\u001b[0m,      \u001b[2m# Collect optimization stats\u001b[0m\r\n"]
[7.3, "o", "    \u001b[0;36mDetailedProgressCallback\u001b[0m  \u001b[2m# Comprehensive output\u001b[0m\r\n"]
[7.65, "o", ")\r\n"]
[8.0, "o", "\r\n"]
[8.25, "o", "\u001b[0;36m@traigent.optimize\u001b[0m(\r\n"]
[8.6, "o", "    configuration_space={\u001b[0;32m\"model\"\u001b[0m: [\"gpt-4o-mini\", \"gpt-4o\"]},\r\n"]
[8.95, "o", "    objectives=[\u001b[0;32m\"accuracy\"\u001b[0m],\r\n"]
[9.3, "o", "    eval_dataset=\u001b[0;32m\"data/callback_eval.jsonl\"\u001b[0m,\r\n"]
[9.65, "o", "    callbacks=[\r\n"]
[10.0, "o", "        ProgressBarCallback(width=\u001b[0;36m50\u001b[0m),\r\n"]
[10.35, "o", "        StatisticsCallback()\r\n"]
[10.7, "o", "    ]\r\n"]
[11.05, "o", ")\r\n"]
[11.4, "o", "\u001b[0;34mdef\u001b[0m \u001b[1;33mmy_agent\u001b[0m(query: str) -> str:\r\n"]
[11.75, "o", "    ...\r\n"]
[12.1, "o", "\r\n"]
[12.35, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[12.7, "o", "\u001b[0;36m\u001b[1m# ProgressBarCallback in Action\u001b[0m\r\n"]
[13.05, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[13.4, "o", "\r\n"]
[13.65, "o", "Starting optimization with \u001b[0;36mgrid search\u001b[0m...\r\n"]
[14.0, "o", "Objectives: \u001b[0;32maccuracy\u001b[0m\r\n"]
[14.35, "o", "Evaluation dataset: \u001b[0;32mdata/callback_eval.jsonl\u001b[0m\r\n"]
[14.7, "o", "Configuration space: \u001b[1m5 combinations\u001b[0m\r\n"]
[15.05, "o", "\r\n"]
[15.3, "o", "[\u001b[0;32m\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u001b[0m\u001b[2m\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u001b[0m]  20% (1/5) Best: 0.72\r\n"]
[15.65, "o", "[\u001b[0;32m\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u001b[0m\u001b[2m\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u001b[0m]  40% (2/5) Best: \u001b[0;32m0.78\u001b[0m\r\n"]
[16.0, "o", "[\u001b[0;32m\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u001b[0m\u001b[2m\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u001b[0m]  60% (3/5) Best: \u001b[0;32m0.85\u001b[0m\r\n"]
[16.35, "o", "[\u001b[0;32m\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u001b[0m\u001b[2m\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u001b[0m]  80% (4/5) Best: 0.85\r\n"]
[16.7, "o", "[\u001b[0;32m\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u001b[0m] 100% (5/5) Best: \u001b[0;32m\u001b[1m0.89\u001b[0m\r\n"]
[17.05, "o", "\r\n"]
[17.3, "o", "\u001b[0;32m\u2713\u001b[0m Optimization complete! Best score: \u001b[0;32m\u001b[1m0.89\u001b[0m\r\n"]
[17.65, "o", "\r\n"]
[17.9, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[18.25, "o", "\u001b[0;36m\u001b[1m# Creating a Custom Callback\u001b[0m\r\n"]
[18.6, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[18.95, "o", "\r\n"]
[19.2, "o", "\u001b[0;35mfrom\u001b[0m traigent.utils.callbacks \u001b[0;35mimport\u001b[0m OptimizationCallback\r\n"]
[19.55, "o", "\r\n"]
[19.8, "o", "\u001b[0;34mclass\u001b[0m \u001b[1;33mSlackNotificationCallback\u001b[0m(OptimizationCallback):\r\n"]
[20.15, "o", "    \u001b[2m\"\"\"Send Slack notifications on optimization events.\"\"\"\u001b[0m\r\n"]
[20.5, "o", "\r\n"]
[20.75, "o", "    \u001b[0;34mdef\u001b[0m \u001b[0;36mon_optimization_start\u001b[0m(self, config_space, objectives, algorithm):\r\n"]
[21.1, "o", "        slack.post(f\u001b[0;32m\"\ud83d\ude80 Optimization started: {algorithm}\"\u001b[0m)\r\n"]
[21.45, "o", "\r\n"]
[21.7, "o", "    \u001b[0;34mdef\u001b[0m \u001b[0;36mon_trial_complete\u001b[0m(self, trial, progress):\r\n"]
[22.05, "o", "        \u001b[0;35mif\u001b[0m progress.best_score \u001b[0;35mand\u001b[0m progress.best_score > \u001b[0;36m0.9\u001b[0m:\r\n"]
[22.4, "o", "            slack.post(f\u001b[0;32m\"\ud83c\udfaf New best score: {progress.best_score:.1%}\"\u001b[0m)\r\n"]
[22.75, "o", "\r\n"]
[23.0, "o", "    \u001b[0;34mdef\u001b[0m \u001b[0;36mon_optimization_complete\u001b[0m(self, result):\r\n"]
[23.35, "o", "        slack.post(f\u001b[0;32m\"\u2705 Done! Best: {result.best_config}\"\u001b[0m)\r\n"]
[23.7, "o", "\r\n"]
[23.95, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[24.3, "o", "\u001b[0;36m\u001b[1m# Parameter Importance Analysis\u001b[0m\r\n"]
[24.65, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[25.0, "o", "\r\n"]
[25.25, "o", "stats_callback = StatisticsCallback()\r\n"]
[25.6, "o", "\r\n"]
[25.85, "o", "\u001b[2m# After optimization...\u001b[0m\r\n"]
[26.2, "o", "importance = stats_callback.get_parameter_importance()\r\n"]
[26.55, "o", "\r\n"]
[26.8, "o", "\u001b[1mParameter Importance:\u001b[0m\r\n"]
[27.15, "o", "  model:       \u001b[0;32m\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2591\u2591\u001b[0m \u001b[1m0.85\u001b[0m  \u001b[2m\u2190 Most impactful\u001b[0m\r\n"]
[27.5, "o", "  temperature: \u001b[1;33m\u2588\u2588\u2588\u2588\u2591\u2591\u2591\u2591\u2591\u2591\u001b[0m \u001b[1m0.42\u001b[0m\r\n"]
[27.85, "o", "  max_tokens:  \u001b[2m\u2588\u2588\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u001b[0m \u001b[1m0.18\u001b[0m\r\n"]
[28.2, "o", "\r\n"]
[28.45, "o", "\u001b[2m\u2192 Model choice has the most impact on results!\u001b[0m\r\n"]
[28.8, "o", "\r\n"]
[29.05, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[29.4, "o", "\u001b[1mCallbacks enable:\u001b[0m\r\n"]
[29.75, "o", "  \u001b[0;32m\u2713\u001b[0m Real-time monitoring dashboards\r\n"]
[30.1, "o", "  \u001b[0;32m\u2713\u001b[0m Slack/email notifications\r\n"]
[30.45, "o", "  \u001b[0;32m\u2713\u001b[0m Custom logging and metrics\r\n"]
[30.8, "o", "  \u001b[0;32m\u2713\u001b[0m Early stopping conditions\r\n"]
[31.15, "o", "  \u001b[0;32m\u2713\u001b[0m Parameter importance analysis\r\n"]
[31.5, "o", "\r\n"]
[34.75, "o", ""]
