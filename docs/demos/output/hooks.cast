[3.8299999999999965, "o", "\r\n"]
[4.3299999999999965, "o", "\r\n"]
[4.349999999999996, "o", "from traigent.utils.callbacks import (\r\n"]
[4.399999999999996, "o", "    ProgressBarCallback,    # Visual progress bar\r\n"]
[4.449999999999996, "o", "    LoggingCallback,        # Log all events\r\n"]
[4.499999999999996, "o", "    StatisticsCallback,     # Collect optimization stats\r\n"]
[4.549999999999995, "o", "    DetailedProgressCallback # Comprehensive output\r\n"]
[4.599999999999995, "o", ")\r\n"]
[4.649999999999995, "o", "\r\n"]
[4.669999999999995, "o", "@traigent.optimize(\r\n"]
[4.719999999999994, "o", "    configuration_space={\"model\": [\"gpt-4o-mini\", \"gpt-4o\"]},\r\n"]
[4.769999999999994, "o", "    objectives=[\"accuracy\"],\r\n"]
[4.819999999999994, "o", "    callbacks=[\r\n"]
[4.869999999999994, "o", "        ProgressBarCallback(width=50),\r\n"]
[4.919999999999994, "o", "        StatisticsCallback()\r\n"]
[4.9699999999999935, "o", "    ]\r\n"]
[5.019999999999993, "o", ")\r\n"]
[5.069999999999993, "o", "def my_agent(query: str) -> str:\r\n"]
[5.119999999999993, "o", "    ...\r\n"]
