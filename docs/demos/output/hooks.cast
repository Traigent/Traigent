[2.1400000000000015, "o", "\r\n"]
[2.6400000000000015, "o", "\r\n"]
[2.6600000000000015, "o", "Available callback events:\r\n"]
[2.7100000000000013, "o", "  on_optimization_start  - Called when optimization begins\r\n"]
[2.760000000000001, "o", "  on_trial_start         - Called before each trial\r\n"]
[2.810000000000001, "o", "  on_trial_complete      - Called after each trial\r\n"]
[2.8600000000000008, "o", "  on_optimization_complete - Called when optimization ends\r\n"]
