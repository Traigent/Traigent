[0.0, "o", "\u001b[H\u001b[2J\u001b[3J\u001b[0;34m\u001b[1m\u250c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2510\u001b[0m\r\n"]
[0.35, "o", "\u001b[0;34m\u001b[1m\u2502  \ud83d\udee1\ufe0f  Traigent: Git Hooks for Agent Validation                   \u2502\u001b[0m\r\n"]
[0.7, "o", "\u001b[0;34m\u001b[1m\u2514\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2518\u001b[0m\r\n"]
[1.05, "o", "\r\n"]
[1.3, "o", "\u001b[2mPrevent expensive mistakes \u001b[1mBEFORE\u001b[0m\u001b[2m they reach production!\u001b[0m\r\n"]
[1.65, "o", "\r\n"]
[1.9, "o", "Available hooks:\r\n"]
[2.25, "o", "  \u001b[0;36mtraigent-validate\u001b[0m     \u001b[2m\u2500\u001b[0m Validates agent config against constraints\r\n"]
[2.6, "o", "  \u001b[0;36mtraigent-performance\u001b[0m  \u001b[2m\u2500\u001b[0m Ensures config meets performance baseline\r\n"]
[2.95, "o", "  \u001b[0;36mtraigent-cost\u001b[0m         \u001b[2m\u2500\u001b[0m Enforces cost budget limits\r\n"]
[3.3, "o", "\r\n"]
[3.55, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[3.9, "o", "\u001b[0;36m\u001b[1m# Step 1: Install Traigent hooks\u001b[0m\r\n"]
[4.25, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
