[41.1, "o", "Running Traigent validation hooks...\r\n"]
[41.45, "o", "\r\n"]
[41.7, "o", "[\u001b[0;36mtraigent-validate\u001b[0m] Checking agent configurations...\r\n"]
[42.05, "o", "  Found 1 decorated function: \u001b[1msupport_agent\u001b[0m\r\n"]
[42.4, "o", "  Model: gpt-4o-mini ............. \u001b[0;32m\u2713 ALLOWED\u001b[0m\r\n"]
[42.75, "o", "  Est. cost: $0.008/query ........ \u001b[0;32m\u2713 WITHIN BUDGET\u001b[0m\r\n"]
[43.1, "o", "\r\n"]
