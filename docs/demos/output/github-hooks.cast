[19.4, "o", "Running Traigent validation hooks...\r\n"]
[19.549999999999997, "o", "\r\n"]
[19.65, "o", "[\u001b[0;36mtraigent-validate\u001b[0m] Checking agent configurations...\r\n"]
[19.799999999999997, "o", "  Found 1 decorated function: \u001b[1msupport_agent\u001b[0m\r\n"]
[19.949999999999996, "o", "  Model: gpt-4o-mini ............. \u001b[0;32m\u2713 ALLOWED\u001b[0m\r\n"]
[20.099999999999994, "o", "  Est. cost: $0.008/query ........ \u001b[0;32m\u2713 WITHIN BUDGET\u001b[0m\r\n"]
[20.249999999999993, "o", "\r\n"]
