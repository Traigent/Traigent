[41.8, "o", "Running Traigent validation hooks...\r\n"]
[42.15, "o", "\r\n"]
[42.4, "o", "[\u001b[0;36mtraigent-validate\u001b[0m] Checking agent configurations...\r\n"]
[42.75, "o", "  Found 1 decorated function: \u001b[1msupport_agent\u001b[0m\r\n"]
