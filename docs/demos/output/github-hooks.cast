[30.699999999999886, "o", "Running Traigent validation hooks...\r\n"]
[30.849999999999884, "o", "\r\n"]
[30.949999999999886, "o", "[\u001b[0;36mtraigent-validate\u001b[0m] Checking agent configurations...\r\n"]
[31.099999999999884, "o", "  Found 1 decorated function: \u001b[1mexpensive_agent\u001b[0m\r\n"]
[31.249999999999883, "o", "\r\n"]
[31.349999999999884, "o", "\u001b[0;31m\u250c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2510\u001b[0m\r\n"]
[31.499999999999883, "o", "\u001b[0;31m\u2502  \u001b[1mVALIDATION ERRORS\u001b[0m\u001b[0;31m                                              \u2502\u001b[0m\r\n"]
[31.64999999999988, "o", "\u001b[0;31m\u251c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2524\u001b[0m\r\n"]
[31.79999999999988, "o", "\u001b[0;31m\u2502\u001b[0m  \u001b[0;31m\u2717\u001b[0m Model '\u001b[1mgpt-4-32k\u001b[0m' is in \u001b[0;31mblocked_models\u001b[0m list          \u001b[0;31m\u2502\u001b[0m\r\n"]
[31.94999999999988, "o", "\u001b[0;31m\u2502\u001b[0m    Reason: Too expensive for production                       \u001b[0;31m\u2502\u001b[0m\r\n"]
[32.09999999999988, "o", "\u001b[0;31m\u2502\u001b[0m                                                                \u001b[0;31m\u2502\u001b[0m\r\n"]
[32.24999999999988, "o", "\u001b[0;31m\u2502\u001b[0m  \u001b[0;31m\u2717\u001b[0m Est. cost \u001b[1;33m$0.12/query\u001b[0m exceeds \u001b[0;32mmax_cost_per_query\u001b[0m      \u001b[0;31m\u2502\u001b[0m\r\n"]
[32.39999999999988, "o", "\u001b[0;31m\u2502\u001b[0m    Limit: $0.05/query                                         \u001b[0;31m\u2502\u001b[0m\r\n"]
[32.549999999999876, "o", "\u001b[0;31m\u2514\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2518\u001b[0m\r\n"]
[32.699999999999875, "o", "\r\n"]
[32.799999999999876, "o", "\u001b[0;31m\u001b[1m\u2717 PUSH REJECTED\u001b[0m: Agent configuration violates constraints\r\n"]
[32.949999999999875, "o", "\r\n"]
[33.049999999999876, "o", "\u001b[2mTo bypass (not recommended): git push --no-verify\u001b[0m\r\n"]
[33.199999999999875, "o", "\r\n"]
[33.299999999999876, "o", "\u001b[1mTo fix:\u001b[0m\r\n"]
[33.449999999999875, "o", "  1. Use an allowed model: \u001b[0;32mgpt-4o-mini\u001b[0m, \u001b[0;32mgpt-4o\u001b[0m, \u001b[0;32mclaude-3-haiku\u001b[0m\r\n"]
[33.59999999999987, "o", "  2. Or request budget increase in traigent.yml\r\n"]
[33.74999999999987, "o", "\r\n"]
[33.84999999999987, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[33.99999999999987, "o", "\u001b[0;32m\u001b[1m# Step 5: Fix and push successfully\u001b[0m\r\n"]
[34.14999999999987, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[34.29999999999987, "o", "\r\n"]
[34.39999999999987, "o", "\u001b[0;36m@traigent.optimize\u001b[0m(\r\n"]
[34.54999999999987, "o", "    configuration_space={\r\n"]
[34.69999999999987, "o", "        \u001b[0;32m\"model\"\u001b[0m: [\"gpt-4o-mini\", \"gpt-4o\"],  \u001b[2m# Fixed!\u001b[0m\r\n"]
[34.849999999999866, "o", "        \u001b[0;32m\"temperature\"\u001b[0m: [0.1, 0.5]\r\n"]
[34.999999999999865, "o", "    }\r\n"]
