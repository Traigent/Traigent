[46.05, "o", "\r\n"]
[46.3, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[46.65, "o", "\u001b[0;31m\u001b[1m# Step 4: Push an INVALID configuration\u001b[0m\r\n"]
[47.0, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[47.35, "o", "\r\n"]
[47.6, "o", "\u001b[0;36m@traigent.optimize\u001b[0m(\r\n"]
[47.95, "o", "    configuration_space={\r\n"]
[48.3, "o", "        \u001b[0;31m\"model\"\u001b[0m: [\"gpt-4-32k\"],        \u001b[0;31m# BLOCKED model!\u001b[0m\r\n"]
[48.65, "o", "        \u001b[0;31m\"temperature\"\u001b[0m: [0.9]\r\n"]
[49.0, "o", "    },\r\n"]
[49.35, "o", "    objectives=[\u001b[0;32m\"accuracy\"\u001b[0m, \u001b[0;32m\"cost\"\u001b[0m],\r\n"]
[49.7, "o", "    eval_dataset=\u001b[0;32m\"data/support_eval.jsonl\"\u001b[0m\r\n"]
[50.05, "o", ")\r\n"]
[50.4, "o", "\u001b[0;34mdef\u001b[0m \u001b[1;33mexpensive_agent\u001b[0m(query: str) -> str:\r\n"]
[50.75, "o", "    llm = ChatOpenAI(model=\u001b[0;31m\"gpt-4-32k\"\u001b[0m, temperature=\u001b[0;36m0.9\u001b[0m)\r\n"]
[51.1, "o", "    \u001b[0;35mreturn\u001b[0m llm.invoke(query).content\r\n"]
