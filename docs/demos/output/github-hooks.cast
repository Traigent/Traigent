[20.499999999999993, "o", "  Accuracy: 0.89 ................. \u001b[0;32m\u2713 PASSES\u001b[0m (min: 0.85)\r\n"]
[20.64999999999999, "o", "  Latency: 120ms ................. \u001b[0;32m\u2713 PASSES\u001b[0m (max: 500ms)\r\n"]
[20.79999999999999, "o", "\r\n"]
