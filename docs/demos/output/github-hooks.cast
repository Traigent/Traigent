[0.0, "o", "\u001b[H\u001b[2J\u001b[3J\u001b[0;34m\u001b[1m\u250c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2510\u001b[0m\r\n"]
[0.15, "o", "\u001b[0;34m\u001b[1m\u2502  \ud83d\udee1\ufe0f  TraiGent: Git Hooks for Agent Validation                   \u2502\u001b[0m\r\n"]
[0.3, "o", "\u001b[0;34m\u001b[1m\u2514\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2518\u001b[0m\r\n"]
[0.44999999999999996, "o", "\r\n"]
[0.5499999999999999, "o", "\u001b[2mPrevent expensive mistakes \u001b[1mBEFORE\u001b[0m\u001b[2m they reach production!\u001b[0m\r\n"]
[0.7, "o", "\r\n"]
[0.7999999999999999, "o", "Available hooks:\r\n"]
[0.95, "o", "  \u001b[0;36mtraigent-validate\u001b[0m     \u001b[2m\u2500\u001b[0m Validates agent config against constraints\r\n"]
[1.0999999999999999, "o", "  \u001b[0;36mtraigent-performance\u001b[0m  \u001b[2m\u2500\u001b[0m Ensures config meets performance baseline\r\n"]
[1.2499999999999998, "o", "  \u001b[0;36mtraigent-cost\u001b[0m         \u001b[2m\u2500\u001b[0m Enforces cost budget limits\r\n"]
[1.3999999999999997, "o", "\r\n"]
[1.4999999999999998, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[1.6499999999999997, "o", "\u001b[0;36m\u001b[1m# Step 1: Install Traigent hooks\u001b[0m\r\n"]
[1.7999999999999996, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
