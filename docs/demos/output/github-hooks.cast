[11.19, "o", "Installing Traigent Git hooks...\r\n"]
[11.54, "o", "  \u001b[0;32m\u2713\u001b[0m Installed: .git/hooks/pre-push (traigent-validate)\r\n"]
[11.89, "o", "  \u001b[0;32m\u2713\u001b[0m Installed: .git/hooks/pre-commit (traigent-config-check)\r\n"]
[12.24, "o", "\r\n"]
[12.49, "o", "\u001b[0;32mHooks installed successfully!\u001b[0m\r\n"]
[12.84, "o", "\r\n"]
[13.09, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[13.44, "o", "\u001b[0;36m\u001b[1m# Step 2: Define constraints in traigent.yml\u001b[0m\r\n"]
[13.79, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[14.14, "o", "\r\n"]
[14.39, "o", "\u001b[2m# traigent.yml - Agent configuration constraints\u001b[0m\r\n"]
[14.74, "o", "\u001b[0;36mvalidation\u001b[0m:\r\n"]
[15.09, "o", "  \u001b[0;36mhooks\u001b[0m:\r\n"]
[15.44, "o", "    \u001b[0;36mpre-push\u001b[0m:\r\n"]
[15.79, "o", "      - traigent-validate\r\n"]
[16.14, "o", "      - traigent-performance\r\n"]
[16.49, "o", "\r\n"]
[16.74, "o", "\u001b[0;36mconstraints\u001b[0m:\r\n"]
[17.09, "o", "  \u001b[2m# Cost constraints\u001b[0m\r\n"]
[17.44, "o", "  \u001b[0;32mmax_cost_per_query\u001b[0m: \u001b[1;33m0.05\u001b[0m       \u001b[2m# $0.05 max per query\u001b[0m\r\n"]
[17.79, "o", "  \u001b[0;32mmax_monthly_budget\u001b[0m: \u001b[1;33m1000\u001b[0m       \u001b[2m# $1000/month limit\u001b[0m\r\n"]
[18.14, "o", "\r\n"]
[18.39, "o", "  \u001b[2m# Performance constraints\u001b[0m\r\n"]
[18.74, "o", "  \u001b[0;32mmin_accuracy\u001b[0m: \u001b[0;36m0.85\u001b[0m             \u001b[2m# 85% minimum accuracy\u001b[0m\r\n"]
[19.09, "o", "  \u001b[0;32mmax_latency_ms\u001b[0m: \u001b[0;36m500\u001b[0m            \u001b[2m# 500ms max response time\u001b[0m\r\n"]
[19.44, "o", "\r\n"]
[19.69, "o", "  \u001b[2m# Model constraints\u001b[0m\r\n"]
[20.04, "o", "  \u001b[0;32mallowed_models\u001b[0m:\r\n"]
[20.39, "o", "    - gpt-4o-mini\r\n"]
[20.74, "o", "    - gpt-4o\r\n"]
[21.09, "o", "    - claude-3-haiku\r\n"]
[21.44, "o", "  \u001b[0;31mblocked_models\u001b[0m:\r\n"]
[21.79, "o", "    - gpt-4-32k                \u001b[2m# Too expensive\u001b[0m\r\n"]
[22.14, "o", "\r\n"]
[22.39, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[22.74, "o", "\u001b[0;32m\u001b[1m# Step 3: Push a VALID configuration\u001b[0m\r\n"]
[23.09, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[23.44, "o", "\r\n"]
[23.69, "o", "\u001b[0;36m@traigent.optimize\u001b[0m(\r\n"]
[24.04, "o", "    configuration_space={\r\n"]
[24.39, "o", "        \u001b[0;32m\"model\"\u001b[0m: [\"gpt-4o-mini\"],      \u001b[2m# Allowed model \u2713\u001b[0m\r\n"]
[24.74, "o", "        \u001b[0;32m\"temperature\"\u001b[0m: [0.1, 0.3]\r\n"]
[25.09, "o", "    }\r\n"]
[25.44, "o", ")\r\n"]
[25.79, "o", "\u001b[0;34mdef\u001b[0m \u001b[1;33msupport_agent\u001b[0m(query: str) -> str:\r\n"]
[26.14, "o", "    llm = ChatOpenAI(model=\u001b[0;32m\"gpt-4o-mini\"\u001b[0m, temperature=\u001b[0;36m0.1\u001b[0m)\r\n"]
[26.49, "o", "    \u001b[0;35mreturn\u001b[0m llm.invoke(query).content\r\n"]
[26.84, "o", "\r\n"]
