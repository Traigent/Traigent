[15.779999999999925, "o", "\r\n"]
[16.279999999999923, "o", "\r\n"]
[16.299999999999923, "o", "@traigent.optimize(\r\n"]
[16.349999999999923, "o", "    configuration_space={\r\n"]
[16.399999999999924, "o", "        \"model\": [\"gpt-4o-mini\"],      # Allowed model\r\n"]
[16.449999999999925, "o", "        \"temperature\": [0.1, 0.3]\r\n"]
[16.499999999999925, "o", "    }\r\n"]
[16.549999999999926, "o", ")\r\n"]
[16.599999999999927, "o", "def support_agent(query: str) -> str:\r\n"]
[16.649999999999928, "o", "    llm = ChatOpenAI(model=\"gpt-4o-mini\", temperature=0.1)\r\n"]
[16.69999999999993, "o", "    return llm.invoke(query).content\r\n"]
