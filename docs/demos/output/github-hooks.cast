[4.570000000000001, "o", "\r\n"]
[5.370000000000001, "o", "Installing Traigent Git hooks...\r\n"]
[5.520000000000001, "o", "  \u001b[0;32m\u2713\u001b[0m Installed: .git/hooks/pre-push (traigent-validate)\r\n"]
[5.670000000000002, "o", "  \u001b[0;32m\u2713\u001b[0m Installed: .git/hooks/pre-commit (traigent-config-check)\r\n"]
[5.820000000000002, "o", "\r\n"]
[5.920000000000002, "o", "\u001b[0;32mHooks installed successfully!\u001b[0m\r\n"]
[6.070000000000002, "o", "\r\n"]
[6.170000000000002, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[6.320000000000002, "o", "\u001b[0;36m\u001b[1m# Step 2: Define constraints in traigent.yml\u001b[0m\r\n"]
[6.470000000000002, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[6.620000000000003, "o", "\r\n"]
[6.720000000000002, "o", "\u001b[2m# traigent.yml - Agent configuration constraints\u001b[0m\r\n"]
[6.870000000000003, "o", "\u001b[0;36mvalidation\u001b[0m:\r\n"]
[7.020000000000003, "o", "  \u001b[0;36mhooks\u001b[0m:\r\n"]
[7.1700000000000035, "o", "    \u001b[0;36mpre-push\u001b[0m:\r\n"]
[7.320000000000004, "o", "      - traigent-validate\r\n"]
[7.470000000000004, "o", "      - traigent-performance\r\n"]
[7.6200000000000045, "o", "\r\n"]
[7.720000000000004, "o", "\u001b[0;36mconstraints\u001b[0m:\r\n"]
[7.8700000000000045, "o", "  \u001b[2m# Cost constraints\u001b[0m\r\n"]
[8.020000000000005, "o", "  \u001b[0;32mmax_cost_per_query\u001b[0m: \u001b[1;33m0.05\u001b[0m       \u001b[2m# $0.05 max per query\u001b[0m\r\n"]
[8.170000000000005, "o", "  \u001b[0;32mmax_monthly_budget\u001b[0m: \u001b[1;33m1000\u001b[0m       \u001b[2m# $1000/month limit\u001b[0m\r\n"]
[8.320000000000006, "o", "\r\n"]
[8.420000000000005, "o", "  \u001b[2m# Performance constraints\u001b[0m\r\n"]
[8.570000000000006, "o", "  \u001b[0;32mmin_accuracy\u001b[0m: \u001b[0;36m0.85\u001b[0m             \u001b[2m# 85% minimum accuracy\u001b[0m\r\n"]
[8.720000000000006, "o", "  \u001b[0;32mmax_latency_ms\u001b[0m: \u001b[0;36m500\u001b[0m            \u001b[2m# 500ms max response time\u001b[0m\r\n"]
[8.870000000000006, "o", "\r\n"]
[8.970000000000006, "o", "  \u001b[2m# Model constraints\u001b[0m\r\n"]
[9.120000000000006, "o", "  \u001b[0;32mallowed_models\u001b[0m:\r\n"]
[9.270000000000007, "o", "    - gpt-4o-mini\r\n"]
[9.420000000000007, "o", "    - gpt-4o\r\n"]
[9.570000000000007, "o", "    - claude-3-haiku\r\n"]
[9.720000000000008, "o", "  \u001b[0;31mblocked_models\u001b[0m:\r\n"]
[9.870000000000008, "o", "    - gpt-4-32k                \u001b[2m# Too expensive\u001b[0m\r\n"]
[10.020000000000008, "o", "\r\n"]
[10.120000000000008, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[10.270000000000008, "o", "\u001b[0;32m\u001b[1m# Step 3: Push a VALID configuration\u001b[0m\r\n"]
[10.420000000000009, "o", "\u001b[2m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[10.57000000000001, "o", "\r\n"]
[10.670000000000009, "o", "\u001b[0;36m@traigent.optimize\u001b[0m(\r\n"]
[10.82000000000001, "o", "    configuration_space={\r\n"]
[10.97000000000001, "o", "        \u001b[0;32m\"model\"\u001b[0m: [\"gpt-4o-mini\"],      \u001b[2m# Allowed model \u2713\u001b[0m\r\n"]
[11.12000000000001, "o", "        \u001b[0;32m\"temperature\"\u001b[0m: [0.1, 0.3]\r\n"]
[11.27000000000001, "o", "    }\r\n"]
[11.42000000000001, "o", ")\r\n"]
[11.570000000000011, "o", "\u001b[0;34mdef\u001b[0m \u001b[1;33msupport_agent\u001b[0m(query: str) -> str:\r\n"]
[11.720000000000011, "o", "    llm = ChatOpenAI(model=\u001b[0;32m\"gpt-4o-mini\"\u001b[0m, temperature=\u001b[0;36m0.1\u001b[0m)\r\n"]
[11.870000000000012, "o", "    \u001b[0;35mreturn\u001b[0m llm.invoke(query).content\r\n"]
