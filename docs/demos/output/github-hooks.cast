[12.119999999999944, "o", "s"]
[12.449999999999944, "o", "\r\n"]
[12.949999999999944, "o", "validation:\r\n"]
[12.999999999999945, "o", "  hooks:\r\n"]
[13.049999999999946, "o", "    pre-push:\r\n"]
[13.099999999999946, "o", "      - traigent-validate\r\n"]
[13.149999999999947, "o", "      - traigent-performance\r\n"]
[13.199999999999948, "o", "\r\n"]
[13.219999999999947, "o", "constraints:\r\n"]
[13.269999999999948, "o", "  # Cost constraints\r\n"]
[13.319999999999949, "o", "  max_cost_per_query: 0.05      # $0.05 max per query\r\n"]
[13.36999999999995, "o", "  max_monthly_budget: 1000      # $1000/month limit\r\n"]
[13.41999999999995, "o", "\r\n"]
[13.43999999999995, "o", "  # Performance constraints\r\n"]
[13.48999999999995, "o", "  min_accuracy: 0.85            # 85% minimum accuracy\r\n"]
[13.539999999999951, "o", "  max_latency_ms: 500           # 500ms max response time\r\n"]
[13.589999999999952, "o", "\r\n"]
[13.609999999999951, "o", "  # Model constraints\r\n"]
[13.659999999999952, "o", "  allowed_models:\r\n"]
[13.709999999999953, "o", "    - gpt-4o-mini\r\n"]
[13.759999999999954, "o", "    - gpt-4o\r\n"]
[13.809999999999954, "o", "    - claude-3-haiku\r\n"]
[13.859999999999955, "o", "  blocked_models:\r\n"]
[13.909999999999956, "o", "    - gpt-4-32k                 # Too expensive for production\r\n"]
[13.959999999999956, "o", "\r\n"]
[13.979999999999956, "o", "#"]
